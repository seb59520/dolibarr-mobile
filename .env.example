# Dolibarr Mobile — variables d'environnement (build / debug)
# Copiez en .env (ignoré par git) et adaptez.

# URL par défaut proposée à l'écran de connexion (l'utilisateur peut modifier)
# Laissez vide en production pour forcer la saisie.
DEFAULT_DOLIBARR_URL=https://erp.exemple.com

# Mode debug : active les logs réseau verbeux et la galerie de composants.
# Doit valoir "true" ou "false". Forcé à false en build release.
DEBUG_MODE=true

# Tuile cartographique par défaut (template URL OSM).
# Override possible côté Paramètres dans l'app.
DEFAULT_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
DEFAULT_MAP_ATTRIBUTION=© OpenStreetMap contributors

# Délai du splash en ms (max 1500 conformément au design).
SPLASH_DELAY_MS=800
